<UserControl x:Class="InventoryApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="Dashboard" Style="{StaticResource SectionTitle}"/>
                <Button Content="↻  Refresh" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Stat Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="28"/>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="34" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Total Products" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⚠️" FontSize="28"/>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="34" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Low Stock Items" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🏷️" FontSize="28"/>
                        <TextBlock Text="{Binding TotalCategories}" FontSize="34" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Categories" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="🏢" FontSize="28"/>
                        <TextBlock Text="{Binding TotalSuppliers}" FontSize="34" FontWeight="Bold"
                                   Foreground="#ED8936" Margin="0,8,0,4"/>
                        <TextBlock Text="Suppliers" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Transactions -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Recent Transactions" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <DataGrid ItemsSource="{Binding RecentTransactions}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderColorBrush}"
                              RowBackground="White" AlternatingRowBackground="#F7FAFC" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"  Binding="{Binding Product.Name}"                                      Width="*"/>
                            <DataGridTextColumn Header="Type"     Binding="{Binding Type}"                                              Width="100"/>
                            <DataGridTextColumn Header="Qty"      Binding="{Binding Quantity}"                                          Width="60"/>
                            <DataGridTextColumn Header="By"       Binding="{Binding User.Username}"                                     Width="100"/>
                            <DataGridTextColumn Header="Date"     Binding="{Binding TransactionDate, StringFormat=\{0:dd MMM yyyy HH:mm\}}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
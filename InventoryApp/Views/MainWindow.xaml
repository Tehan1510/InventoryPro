<Window x:Class="InventoryApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryApp.ViewModels"
        xmlns:views="clr-namespace:InventoryApp.Views"
        Title="InventoryPro" Width="1100" Height="700"
        WindowStartupLocation="CenterScreen" MinWidth="800" MinHeight="500">

    <!-- Maps each ViewModel type to its View — WPF picks the right one automatically -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <views:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
            <views:CategoriesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}">
            <views:SuppliersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockViewModel}">
            <views:StockView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <DockPanel Grid.Column="0" Background="{StaticResource SidebarBrush}" LastChildFill="False">

            <!-- Branding -->
            <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                <TextBlock Text="📦 InventoryPro" FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Management System" FontSize="11"
                           Foreground="{StaticResource SidebarTextBrush}" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel DockPanel.Dock="Top">
                <Button Content="🏠  Dashboard"  Style="{StaticResource NavButton}" Command="{Binding NavDashboardCommand}"/>
                <Button Content="📦  Products"   Style="{StaticResource NavButton}" Command="{Binding NavProductsCommand}"/>
                <Button Content="🏷️  Categories" Style="{StaticResource NavButton}" Command="{Binding NavCategoriesCommand}"/>
                <Button Content="🏢  Suppliers"  Style="{StaticResource NavButton}" Command="{Binding NavSuppliersCommand}"/>
                <Button Content="📊  Stock"      Style="{StaticResource NavButton}" Command="{Binding NavStockCommand}"/>
            </StackPanel>

            <!-- Bottom: user + logout -->
            <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                <Separator Background="{StaticResource SidebarHoverBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding CurrentUsername, StringFormat='👤  {0}'}"
                           Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,4"/>
                <TextBlock Text="{Binding CurrentRole}" Foreground="{StaticResource SidebarTextBrush}"
                           FontSize="11" Margin="8,0,0,8"/>
                <Button Content="⇠  Sign Out" Style="{StaticResource NavButton}" Command="{Binding LogoutCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- CONTENT AREA — ContentControl renders the current ViewModel via DataTemplate -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
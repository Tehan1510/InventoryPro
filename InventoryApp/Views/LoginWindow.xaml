<Window x:Class="InventoryApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryApp.ViewModels"
        Title="InventoryPro — Login" Width="440" Height="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Grid VerticalAlignment="Center">
        <Border Style="{StaticResource Card}" Width="370">
            <StackPanel>
                <TextBlock Text="📦" FontSize="44" HorizontalAlignment="Center"/>
                <TextBlock Text="InventoryPro" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,4"/>
                <TextBlock Text="Sign in to your account" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <TextBlock Text="USERNAME" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Input}" Margin="0,0,0,16"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="PwdBox" Style="{StaticResource PasswordInput}" Margin="0,0,0,8"/>

                <!-- Error: hidden when empty via DataTrigger -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,4,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Height="42" Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding IsNotLoading}" Click="LoginButton_Click"
                        Margin="0,0,0,16">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Sign In"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Text" Value="Signing in..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <TextBlock Text="Default: admin / Admin@123" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
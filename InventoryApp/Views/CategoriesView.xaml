<UserControl x:Class="InventoryApp.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Categories" Style="{StaticResource SectionTitle}"/>
            <Button Content="+ Add Category" Style="{StaticResource PrimaryButton}"
                    Command="{Binding ShowAddFormCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderColorBrush}"
                      RowBackground="White" AlternatingRowBackground="#F7FAFC" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="200"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="✏️  Edit"   Style="{StaticResource SecondaryButton}" Command="{Binding EditCommand}"   Margin="0,0,8,0"/>
                <Button Content="🗑  Delete" Style="{StaticResource DangerButton}"    Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <Border Style="{StaticResource Card}"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding FormTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="NAME *" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Input}" Margin="0,0,0,12"/>
                    <TextBlock Text="DESCRIPTION" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Input}" Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="12" Margin="0,0,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Width="100" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="100" Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
<UserControl x:Class="InventoryApp.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Products" Style="{StaticResource SectionTitle}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Input}" Width="220" Margin="0,0,10,0"/>
                <Button Content="+ Add Product" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ShowAddFormCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Product DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderColorBrush}"
                      RowBackground="White" AlternatingRowBackground="#F7FAFC" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"     Binding="{Binding Name}"                                Width="*"/>
                    <DataGridTextColumn Header="SKU"      Binding="{Binding SKU}"                                Width="90"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}"                      Width="110"/>
                    <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}"                      Width="110"/>
                    <DataGridTextColumn Header="Price"    Binding="{Binding Price, StringFormat=\{0:C2\}}"       Width="80"/>
                    <!-- Color-coded stock badge -->
                    <DataGridTemplateColumn Header="Stock" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#C6F6D5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                    <Setter Property="Background" Value="#FED7D7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Quantity}" FontWeight="SemiBold" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#276749"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                        <Setter Property="Foreground" Value="#9B2C2C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action row + form -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="✏️  Edit"   Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditCommand}"   Margin="0,0,8,0"/>
                <Button Content="🗑  Delete" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <!-- Collapsible form -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NAME *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SKU" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormSKU, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="PRICE" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="QUANTITY" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,12,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOW STOCK THRESHOLD" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CATEGORY *" Style="{StaticResource FormLabel}"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding FormSelectedCategory}"
                                      DisplayMemberPath="Name" Style="{StaticResource ComboInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="SUPPLIER (optional)" Style="{StaticResource FormLabel}"/>
                            <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding FormSelectedSupplier}"
                                      DisplayMemberPath="Name" Style="{StaticResource ComboInput}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="DESCRIPTION" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Input}" Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Width="100" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="100" Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>